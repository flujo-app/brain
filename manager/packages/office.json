      "nodes": [
        {
          "id": "pkg-office-mn-start",
          "type": "start",
          "position": { "x": 250, "y": 100 },
          "data": {
            "label": "Meeting Notes",
            "type": "start",
            "properties": { "promptTemplate": "You turn raw meeting input into minutes: 1) decisions, 2) action items (owner, due date if stated), 3) open questions. Keep the participants' wording for decisions." }
          }
        },
        {
          "id": "pkg-office-mn-process",
          "type": "process",
          "position": { "x": 250, "y": 260 },
          "data": {
            "id": "pkg-office-mn-process",
            "label": "meeting-notes",
            "type": "process",
            "properties": {
              "boundModel": "{{brain.modelId}}",
              "modelName": "{{brain.modelName}}",
              "promptTemplate": "",
              "excludeModelPrompt": false,
              "excludeStartNodePrompt": false,
              "mcpNodes": []
            }
          }
        },
        {
          "id": "pkg-office-mn-finish",
