{
  "name": "flujo-brain",
  "version": "0.3.2",
  "description": "A WebGL brain that visualizes FLUJO flows as neurons and their relationships as synapses.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "standalone": "npm run build && npm install --prefix manager && npm run standalone --prefix manager",
    "release": "node scripts/release.mjs"
  },
  "keywords": [
    "flujo",
    "webgl",
    "three.js",
    "visualization",
    "neural",
    "mcp"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/three": "0.169.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "three": "0.169.0"
  },
  "allowScripts": {
    "esbuild@0.21.5": true
  }
}
